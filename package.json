{
  "name": "kai-xiaohua-agent-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared skill, CLI, SDK, and MCP stdio proxy for external agents connecting to Kai Xiaohua.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "doctor": "node packages/cli/bin/xiaohua-agent-kit.js doctor",
    "mcp": "node packages/mcp-stdio-proxy/src/server.js",
    "check": "node packages/cli/bin/xiaohua-agent-kit.js doctor --offline && node packages/mcp-stdio-proxy/src/server.js --self-test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
